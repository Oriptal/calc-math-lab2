= Листинг программы (ключевые фрагменты)

*Прямоугольники (средние), `calc/integrators.cpp`:*
```cpp
double integrateMidRect(const IntegrandFunc &f, double a, double b, int n) {
  if (n <= 0) return std::numeric_limits<double>::quiet_NaN();
  const double h = (b - a) / static_cast<double>(n);
  double sum = 0.0;
  for (int i = 0; i < n; ++i) {
    const double x = a + (i + 0.5) * h;
    sum += f(x);
  }
  return sum * h;
}
```

*Трапеции:*
```cpp
double integrateTrapezoid(const IntegrandFunc &f, double a, double b, int n) {
  const double h = (b - a) / static_cast<double>(n);
  double sum = 0.5 * (f(a) + f(b));
  for (int i = 1; i < n; ++i) sum += f(a + i * h);
  return sum * h;
}
```

*Симпсон:*
```cpp
double integrateSimpson(const IntegrandFunc &f, double a, double b, int n) {
  if (n <= 0 || n % 2 != 0) return std::numeric_limits<double>::quiet_NaN();
  const double h = (b - a) / static_cast<double>(n);
  double sum = f(a) + f(b);
  for (int i = 1; i < n; ++i)
    sum += (i % 2 == 0 ? 2.0 : 4.0) * f(a + i * h);
  return sum * h / 3.0;
}
```

*Правило Рунге (цикл удвоения $n$):*
```cpp
IntegrationResult rungeSolve(IntegrationMethod method, const IntegrandFunc &f,
                             double a, double b, double eps) {
  const int k = methodOrder(method);
  const double denom = std::pow(2.0, k) - 1.0;
  int n = kInitialN;
  double prev = applyMethod(method, f, a, b, n);
  while (n * 2 <= kMaxN) {
    const int nNew = n * 2;
    const double cur = applyMethod(method, f, a, b, nNew);
    const double runge = std::abs(cur - prev) / denom;
    if (runge <= eps) return {cur, nNew, runge, "ok", "Интеграл вычислен."};
    prev = cur;
    n = nNew;
  }
  // ... max_iter ...
}
```

*Итеративное сужение к точке разрыва:*
```cpp
LimitResult limitAtEndpoint(IntegrationMethod method, const IntegrandFunc &f,
                            double c, double other, int side, double eps) {
  const double d0 = std::abs(other - c) * 1e-2;
  double prevI = NaN; int stableCount = 0;
  for (int k = 0; k < 50; ++k) {
    const double sigma = d0 * std::pow(0.5, k);
    double lo = (side > 0 ? c + sigma : other);
    double hi = (side > 0 ? other : c - sigma);
    IntegrationResult inner = rungeSolve(method, f, lo, hi, eps);
    if (std::abs(inner.value) > 1e15) return {NaN, "diverges"};
    if (inner.status == "ok" && std::isfinite(prevI) &&
        std::abs(inner.value - prevI) < 3 * eps) {
      if (++stableCount >= 2) return {inner.value, "ok"};
    } else stableCount = 0;
    prevI = (inner.status == "ok" ? inner.value : NaN);
  }
  return {lastValue, "indeterminate"};
}
```

*Проверка антисимметрии для главного значения:*
```cpp
bool isAntisymmetric(const IntegrandFunc &f, double c, double d) {
  double worst = 0.0;
  for (int i = 0; i < 10; ++i) {
    const double t = i / 9.0;
    const double delta = d * std::pow(1e-3, 1 - t) * std::pow(0.99, t);
    const double fp = f(c + delta), fm = f(c - delta);
    const double denom = std::max({std::abs(fp), std::abs(fm), 1e-30});
    worst = std::max(worst, std::abs(fp + fm) / denom);
  }
  return worst < 1e-6;
}
```

= Вычислительная часть (вариант 5)

Необходимо вычислить интеграл
$ I = integral_2^4 (-2x^3 - 3x^2 + x + 5) d x $

== Точное значение по формуле Ньютона–Лейбница

Первообразная:
$ F(x) = integral (-2x^3 - 3x^2 + x + 5) d x = -x^4/2 - x^3 + x^2/2 + 5 x $

Проверка: $F'(x) = -2x^3 - 3x^2 + x + 5$. *Q.E.D.*

Вычислим значения:
$ F(4) &= -4^4/2 - 4^3 + 4^2/2 + 5 dot 4 = -128 - 64 + 8 + 20 = -164 \
  F(2) &= -2^4/2 - 2^3 + 2^2/2 + 5 dot 2 = -8 - 8 + 2 + 10 = -4 $

$ I = F(4) - F(2) = -164 - (-4) = bold(-160) $

== Численные методы при $n = 10$

Шаг разбиения: $h = (b - a) / n = (4 - 2)/10 = 0.2$.

