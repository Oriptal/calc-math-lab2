digraph LSLinear {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.25, ranksep=0.3, splines=polyline]
  node  [fontname="CMU Serif", fontsize=14, style="filled", fillcolor="#ffffff", color="#000000"]
  edge  [fontname="CMU Serif", fontsize=12, color="#000000"]

  start  [label="Начало: fitLinear", shape=oval, fillcolor="#e6eefc"]
  input  [label=<Ввод: data — n точек (x<SUB>i</SUB>, y<SUB>i</SUB>)>, shape=parallelogram, fillcolor="#f5f5f5"]
  initRes [label=<res.kind = Kind::Linear<BR/>i = 1>, shape=box]
  chkLoop [label=<i ≤ n ?>, shape=diamond, fillcolor="#fff7d1"]
  copy    [label=<xs += {data<SUB>i</SUB>.x}<BR/>ys += {data<SUB>i</SUB>.y}<BR/>i = i + 1>, shape=box]

  reg    [label=<fit = linearCramer(xs, ys)>, shape=box, fillcolor="#eef2ff"]
  chkOk  [label=<fit.ok ?>, shape=diamond, fillcolor="#fff7d1"]
  degen  [label=<res.status = Status::Degenerate>, shape=parallelogram, fillcolor="#fde2e2"]

  setc   [label=<res.coeffs = { fit.slope, fit.intercept }>, shape=box]
  stats  [label=<fillResidualsAndStats(res, data, res.coeffs)>, shape=box, fillcolor="#eef2ff"]
  pear   [label=<res.pearson = computePearson(xs, ys)>, shape=box, fillcolor="#eef2ff"]
  output [label=<Вывод: res>, shape=parallelogram, fillcolor="#dcfce7"]
  stop   [label="Конец", shape=oval, fillcolor="#e6eefc"]

  start -> input -> initRes -> chkLoop
  chkLoop -> copy [label="да"]
  copy -> chkLoop
  chkLoop -> reg [label="нет"]
  reg -> chkOk
  chkOk -> degen [label="нет"]
  degen -> stop
  chkOk -> setc [label="да"]
  setc -> stats -> pear -> output -> stop
}
