digraph LinearCramer {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.25, ranksep=0.3, splines=polyline]
  node  [fontname="CMU Serif", fontsize=14, style="filled", fillcolor="#ffffff", color="#000000"]
  edge  [fontname="CMU Serif", fontsize=12, color="#000000"]

  start  [label="Начало: linearCramer", shape=oval, fillcolor="#e6eefc"]
  input  [label=<Ввод: n точек (x<SUB>i</SUB>, y<SUB>i</SUB>)>, shape=parallelogram, fillcolor="#f5f5f5"]
  zero   [label=<SX = 0<BR/>SXX = 0<BR/>SY = 0<BR/>SXY = 0<BR/>i = 1>, shape=box]
  loopChk [label=<i ≤ n ?>, shape=diamond, fillcolor="#fff7d1"]
  body    [label=<SX = SX + x<SUB>i</SUB><BR/>SXX = SXX + x<SUB>i</SUB> · x<SUB>i</SUB><BR/>SY = SY + y<SUB>i</SUB><BR/>SXY = SXY + x<SUB>i</SUB> · y<SUB>i</SUB><BR/>i = i + 1>, shape=box]

  det     [label=<Δ = SXX · n − SX · SX>, shape=box]
  detChk  [label=<|Δ| &lt; ε ?>, shape=diamond, fillcolor="#fff7d1"]
  degen   [label=<Возврат: LinearFit { ok = false }>, shape=parallelogram, fillcolor="#fde2e2"]

  cramer  [label=<Δ<SUB>1</SUB> = SXY · n − SX · SY<BR/>Δ<SUB>2</SUB> = SXX · SY − SX · SXY<BR/>out.ok = true<BR/>out.slope = Δ<SUB>1</SUB> / Δ<BR/>out.intercept = Δ<SUB>2</SUB> / Δ>, shape=box]
  output  [label=<Возврат: out>, shape=parallelogram, fillcolor="#dcfce7"]
  stop    [label="Конец", shape=oval, fillcolor="#e6eefc"]

  start -> input -> zero -> loopChk
  loopChk -> body [label="да"]
  body -> loopChk
  loopChk -> det [label="нет"]
  det -> detChk
  detChk -> degen [label="да"]
  degen -> stop
  detChk -> cramer [label="нет"]
  cramer -> output -> stop
}
