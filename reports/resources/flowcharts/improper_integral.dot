digraph ImproperIntegral {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.15, ranksep=0.15, splines=polyline]
  node  [fontname="CMU Serif", fontsize=14, style="filled", fillcolor="#ffffff", color="#000000"]
  edge  [fontname="CMU Serif", fontsize=12, color="#000000"]

  start  [label="Начало: Integrator::integrate", shape=oval, fillcolor="#e6eefc"]
  input  [label=<Ввод: f(x), a, b, разрывы<BR/>(EPS, k<SUB>InitialN</SUB>, k<SUB>MaxN</SUB> — поля класса)>, shape=parallelogram, fillcolor="#f5f5f5"]

  chkAB  [label=<a &lt; b?>, shape=diamond, fillcolor="#fff7d1"]
  errAB  [label=<status = error<BR/>value = NaN<BR/>«Левый предел должен быть<BR/>меньше правого»>, shape=parallelogram, fillcolor="#fde2e2"]
  chkEps [label=<EPS &gt; 0 ∧ isFinite(EPS)?>, shape=diamond, fillcolor="#fff7d1"]
  errEps [label=<status = error<BR/>value = NaN<BR/>«Некорректная точность ε»>, shape=parallelogram, fillcolor="#fde2e2"]

  prep   [label=<plan = prepareIntervals(<BR/>a, b, разрывы)>, shape=box, fillcolor="#e6eefc"]
  improperFlag [label=<improper = (|plan.segments| &gt; 1)<BR/>∨ plan.segments<SUB>0</SUB>.limit_at_from<BR/>∨ plan.segments<SUB>0</SUB>.limit_at_to>, shape=box]
  initLoop [label=<total = 0; totalN = 0<BR/>totalRunge = 0<BR/>failedStatus = ""<BR/>k = 0>, shape=box]

  chkSeg [label=<k &lt; |plan.segments|?>, shape=diamond, fillcolor="#fff7d1"]

  callSeg [label=<sr = computeSegmentStandard(<BR/>*this, f, plan.segments<SUB>k</SUB>, EPS)>, shape=box, fillcolor="#e6eefc"]
  chkMax  [label=<sr.status = "max_iter"?>, shape=diamond, fillcolor="#fff7d1"]
  retMax  [label=<status = max_iter<BR/>value = sr.value<BR/>n = sr.n; runge = sr.runge>, shape=parallelogram, fillcolor="#fde2e2"]

  chkOk   [label=<sr.status = "ok"?>, shape=diamond, fillcolor="#fff7d1"]
  fail    [label=<failedStatus = sr.status<BR/>total += isFinite(sr.value)<BR/>&nbsp;&nbsp;&nbsp;? sr.value : 0<BR/>totalN += sr.n<BR/>totalRunge += sr.runge<BR/>выход из цикла>, shape=box]
  acc     [label=<total += sr.value<BR/>totalN += sr.n<BR/>totalRunge += sr.runge<BR/>k = k + 1>, shape=box]

  chkAllOk [label=<failedStatus == ""?>, shape=diamond, fillcolor="#fff7d1"]
  retOk    [label=<status = ok<BR/>value = total<BR/>n = totalN<BR/>runge = totalRunge>, shape=parallelogram, fillcolor="#dcfce7"]

  pv       [label=<pv = tryPrincipalValue(<BR/>*this, f, plan, EPS)>, shape=box, fillcolor="#fef3c7"]
  chkPv    [label=<pv.success ∧<BR/>pv.usedPV?>, shape=diamond, fillcolor="#fff7d1"]
  retPv    [label=<status = ok_principal_value<BR/>value = pv.value<BR/>n = pv.n; runge = pv.runge>, shape=parallelogram, fillcolor="#fef3c7"]

  chkInd   [label=<failedStatus = "indeterminate"?>, shape=diamond, fillcolor="#fff7d1"]
  retInd   [label=<status = indeterminate<BR/>value = total<BR/>n = totalN; runge = totalRunge>, shape=parallelogram, fillcolor="#fde2e2"]
  retDiv   [label=<status = diverges<BR/>value = NaN<BR/>«Интеграл расходится»>, shape=parallelogram, fillcolor="#fde2e2"]

  stop [label="Конец", shape=oval, fillcolor="#e6eefc"]

  start -> input -> chkAB
  chkAB -> errAB [label="нет"]
  errAB -> stop
  chkAB -> chkEps [label="да"]
  chkEps -> errEps [label="нет"]
  errEps -> stop
  chkEps -> prep [label="да"]
  prep -> improperFlag -> initLoop -> chkSeg
  chkSeg -> chkAllOk [label="нет"]
  chkSeg -> callSeg [label="да"]
  callSeg -> chkMax
  chkMax -> retMax [label="да"]
  retMax -> stop
  chkMax -> chkOk [label="нет"]
  chkOk -> acc [label="да"]
  acc -> chkSeg
  chkOk -> fail [label="нет"]
  fail -> chkAllOk

  chkAllOk -> retOk [label="да"]
  retOk -> stop
  chkAllOk -> pv [label="нет"]
  pv -> chkPv
  chkPv -> retPv [label="да"]
  retPv -> stop
  chkPv -> chkInd [label="нет"]
  chkInd -> retInd [label="да"]
  retInd -> stop
  chkInd -> retDiv [label="нет"]
  retDiv -> stop
}
