digraph Lab6Solve {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.28, ranksep=0.32, splines=polyline]
  node  [fontname="CMU Serif", fontsize=14, style="filled", fillcolor="#ffffff", color="#000000"]
  edge  [fontname="CMU Serif", fontsize=12, color="#000000"]

  start  [label="Начало", shape=oval, fillcolor="#e6eefc"]
  input  [label=<Параметры: equationId, x<SUB>0</SUB>, y<SUB>0</SUB>, x<SUB>n</SUB>, h, ε>, shape=parallelogram, fillcolor="#f5f5f5"]

  cint   [label=<x<SUB>n</SUB> &gt; x<SUB>0</SUB> ?>, shape=diamond, fillcolor="#fff7d1"]
  ch     [label=<h &gt; 0 ?>, shape=diamond, fillcolor="#fff7d1"]
  cbig   [label=<h ≤ x<SUB>n</SUB> − x<SUB>0</SUB> ?>, shape=diamond, fillcolor="#fff7d1"]
  ceps   [label=<ε &gt; 0 ?>, shape=diamond, fillcolor="#fff7d1"]
  err    [label=<status = код ошибки<BR/>return res>, shape=parallelogram, fillcolor="#fde2e2"]

  nstep  [label=<steps = round((x<SUB>n</SUB> − x<SUB>0</SUB>) / h)>, shape=box]
  cmany  [label=<steps &gt; kMaxSteps ?>, shape=diamond, fillcolor="#fff7d1"]
  cfew   [label=<steps &lt; 4 ?>, shape=diamond, fillcolor="#fff7d1"]

  prep   [label=<f = equations<SUB>id</SUB>.f<BR/>точн(x) = equations<SUB>id</SUB>.makeExact(x<SUB>0</SUB>, y<SUB>0</SUB>)<BR/>y<SUP>Э</SUP> = УсовЭйлер(f, x<SUB>0</SUB>, y<SUB>0</SUB>, h, steps)<BR/>y<SUP>РК</SUP> = РунгеКутта4(f, x<SUB>0</SUB>, y<SUB>0</SUB>, h, steps)<BR/>y<SUP>М</SUP> = Милна(f, x<SUB>0</SUB>, y<SUB>0</SUB>, h, steps, ε)>, shape=box, fillcolor="#eef2ff"]
  fill   [label=<для i = 0 … steps:<BR/>x<SUB>i</SUB> = x<SUB>0</SUB> + i·h,  таблица<SUB>i</SUB> = (x<SUB>i</SUB>, точн(x<SUB>i</SUB>), y<SUP>Э</SUP><SUB>i</SUB>, y<SUP>РК</SUP><SUB>i</SUB>, y<SUP>М</SUP><SUB>i</SUB>)<BR/>err<SUP>Э</SUP>, err<SUP>РК</SUP>, err<SUP>М</SUP> = max |точн − y|>, shape=box]
  summ   [label=<Эйлер, РК4: оценка R по Рунге + уточнение шага<BR/>Милна: ε = max |точн − y|>, shape=box, fillcolor="#eef2ff"]
  ret    [label=<status = Ok<BR/>return res>, shape=parallelogram, fillcolor="#dcfce7"]
  stop   [label="Конец", shape=oval, fillcolor="#e6eefc"]

  start -> input -> cint
  cint -> ch   [label="да"]
  ch   -> cbig [label="да"]
  cbig -> ceps [label="да"]
  ceps -> nstep [label="да"]

  cint -> err [label="нет"]
  ch   -> err [label="нет"]
  cbig -> err [label="нет"]
  ceps -> err [label="нет"]
  err -> stop

  nstep -> cmany
  cmany -> err [label="да"]
  cmany -> cfew [label="нет"]
  cfew -> err [label="да"]
  cfew -> prep [label="нет"]
  prep -> fill -> summ -> ret -> stop
}
