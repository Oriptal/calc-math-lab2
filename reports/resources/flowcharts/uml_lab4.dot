digraph UMLLab4 {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.5, ranksep=0.65, splines=polyline]
  node  [fontname="CMU Serif", fontsize=12, shape=plaintext]
  edge  [fontname="CMU Serif", fontsize=11, color="#000000", arrowhead=empty]

  LSA [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#ffffff">
      <TR><TD ALIGN="CENTER"><B>LeastSquaresApproximator</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ kMinPoints : size_t = 4</TD></TR>
      <TR><TD ALIGN="LEFT">+ kMaxPoints : size_t = 12</TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ approximate(kind, data) : Result</TD></TR>
      <TR><TD ALIGN="LEFT">+ approximateAll(data) : vec&lt;Result&gt;</TD></TR>
      <TR><TD ALIGN="LEFT">+ evaluate(r, x) : double  &laquo;static&raquo;</TD></TR>
    </TABLE>
  >]

  Result [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#ffffff">
      <TR><TD ALIGN="CENTER"><B>Result</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ kind : Kind</TD></TR>
      <TR><TD ALIGN="LEFT">+ status : Status</TD></TR>
      <TR><TD ALIGN="LEFT">+ coeffs : vec&lt;double&gt;</TD></TR>
      <TR><TD ALIGN="LEFT">+ phi : vec&lt;double&gt;</TD></TR>
      <TR><TD ALIGN="LEFT">+ eps : vec&lt;double&gt;</TD></TR>
      <TR><TD ALIGN="LEFT">+ S, delta, r2 : double</TD></TR>
      <TR><TD ALIGN="LEFT">+ pearson : optional&lt;double&gt;</TD></TR>
    </TABLE>
  >]

  Point [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#ffffff">
      <TR><TD ALIGN="CENTER"><B>Point</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ x : double</TD></TR>
      <TR><TD ALIGN="LEFT">+ y : double</TD></TR>
    </TABLE>
  >]

  Kind [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#fff7d1">
      <TR><TD ALIGN="CENTER"><B>&laquo;enum&raquo; Kind</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">Linear</TD></TR>
      <TR><TD ALIGN="LEFT">Poly2</TD></TR>
      <TR><TD ALIGN="LEFT">Poly3</TD></TR>
      <TR><TD ALIGN="LEFT">Exponential</TD></TR>
      <TR><TD ALIGN="LEFT">Logarithmic</TD></TR>
      <TR><TD ALIGN="LEFT">Power</TD></TR>
    </TABLE>
  >]

  Status [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#fff7d1">
      <TR><TD ALIGN="CENTER"><B>&laquo;enum&raquo; Status</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">Ok</TD></TR>
      <TR><TD ALIGN="LEFT">TooFew</TD></TR>
      <TR><TD ALIGN="LEFT">TooMany</TD></TR>
      <TR><TD ALIGN="LEFT">NonPositiveX</TD></TR>
      <TR><TD ALIGN="LEFT">NonPositiveY</TD></TR>
      <TR><TD ALIGN="LEFT">Degenerate</TD></TR>
    </TABLE>
  >]

  GaussSolver [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#f5f5f5">
      <TR><TD ALIGN="CENTER"><B>GaussSolver</B>  (из ЛР №1)</TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ solve(A, b) : GaussResult</TD></TR>
    </TABLE>
  >]

  ApproximationModule [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#e6eefc">
      <TR><TD ALIGN="CENTER"><B>ApproximationModule</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ approximate(payload) : QVariantMap</TD></TR>
      <TR><TD ALIGN="LEFT">+ sampleApproximation(kind, coeffs, xMin, xMax, n) : QVariantList</TD></TR>
    </TABLE>
  >]

  Backend [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#e6eefc">
      <TR><TD ALIGN="CENTER"><B>Backend : QObject</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">+ approximate(payload) : QVariantMap</TD></TR>
      <TR><TD ALIGN="LEFT">+ sampleApproximation(…) : QVariantList</TD></TR>
      <TR><TD ALIGN="LEFT">… (методы ЛР №1–№3)</TD></TR>
    </TABLE>
  >]

  ModuleApproxQml [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#f5f5f5">
      <TR><TD ALIGN="CENTER"><B>ModuleApproximation.qml</B></TD></TR>
      <HR/>
      <TR><TD ALIGN="LEFT">QML-компонент (RowLayout)</TD></TR>
      <TR><TD ALIGN="LEFT">— редактируемая таблица (x, y)</TD></TR>
      <TR><TD ALIGN="LEFT">— кнопки «Случайные» и «Рассчитать»</TD></TR>
      <TR><TD ALIGN="LEFT">— таблица моделей и общий график</TD></TR>
    </TABLE>
  >]

  Backend -> ApproximationModule [arrowhead=open, label="вызывает"]
  ApproximationModule -> LSA [arrowhead=open, label="использует"]
  LSA -> GaussSolver [arrowhead=open, label="нормальные уравнения"]
  LSA -> Result [arrowhead=open, label="возвращает"]
  LSA -> Point [arrowhead=open, label="принимает"]
  Result -> Kind [arrowhead=open, label="хранит"]
  Result -> Status [arrowhead=open, label="хранит"]
  ModuleApproxQml -> Backend [arrowhead=open, label="Q_INVOKABLE"]
}
