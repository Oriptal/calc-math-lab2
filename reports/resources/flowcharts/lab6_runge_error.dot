digraph Lab6RungeError {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.28, ranksep=0.32, splines=polyline]
  node  [fontname="CMU Serif", fontsize=14, style="filled", fillcolor="#ffffff", color="#000000"]
  edge  [fontname="CMU Serif", fontsize=12, color="#000000"]

  start  [label="Начало", shape=oval, fillcolor="#e6eefc"]
  input  [label=<Параметры: метод, f, x<SUB>0</SUB>, y<SUB>0</SUB>, h, steps>, shape=parallelogram, fillcolor="#f5f5f5"]
  calc   [label=<y<SUP>h</SUP> = solveEndpoint(метод, f, x<SUB>0</SUB>, y<SUB>0</SUB>, h, steps)<BR/>y<SUP>h/2</SUP> = solveEndpoint(метод, f, x<SUB>0</SUB>, y<SUB>0</SUB>, h/2, 2·steps)<BR/>p = methodOrder(метод)<BR/>R = |y<SUP>h</SUP> − y<SUP>h/2</SUP>| / (2<SUP>p</SUP> − 1)>, shape=box, fillcolor="#eef2ff"]
  ret    [label=<return R>, shape=parallelogram, fillcolor="#dcfce7"]
  stop   [label="Конец", shape=oval, fillcolor="#e6eefc"]

  start -> input -> calc -> ret -> stop
}
