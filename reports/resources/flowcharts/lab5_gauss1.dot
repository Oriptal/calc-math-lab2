digraph Lab5Gauss1 {
  graph [fontname="CMU Serif", rankdir=TB, nodesep=0.25, ranksep=0.3, splines=polyline]
  node  [fontname="CMU Serif", fontsize=14, style="filled", fillcolor="#ffffff", color="#000000"]
  edge  [fontname="CMU Serif", fontsize=12, color="#000000"]

  start  [label="Начало", shape=oval, fillcolor="#e6eefc"]
  input  [label=<Параметры: d, nodes, h, X, c>, shape=parallelogram, fillcolor="#f5f5f5"]
  init   [label=<t = (X − nodes<SUB>c</SUB>.x) / h<BR/>result = nodes<SUB>c</SUB>.y<BR/>prod = 1<BR/>fact = 1<BR/>order = 0<BR/>k = 1>, shape=box]
  idx    [label=<idx = c − k / 2>, shape=box]
  chka   [label=<idx &lt; 0 или idx + k &gt; n − 1 ?>, shape=diamond, fillcolor="#fff7d1"]
  half   [label=<half = k / 2>, shape=box]
  par    [label=<k % 2 == 1 ?>, shape=diamond, fillcolor="#fff7d1"]
  fodd   [label=<f = t + half>, shape=box]
  feven  [label=<f = t − half>, shape=box]
  acc    [label=<prod = prod · f<BR/>fact = fact · k<BR/>result = result + prod / fact · d<SUB>k,idx</SUB><BR/>order = k<BR/>k = k + 1>, shape=box]
  output [label=<return result>, shape=parallelogram, fillcolor="#dcfce7"]
  stop   [label="Конец", shape=oval, fillcolor="#e6eefc"]

  start -> input -> init -> idx
  idx -> chka
  chka -> output [label="да"]
  chka -> half [label="нет"]
  half -> par
  par -> fodd [label="да"]
  par -> feven [label="нет"]
  fodd -> acc
  feven -> acc
  acc -> idx
  output -> stop
}
